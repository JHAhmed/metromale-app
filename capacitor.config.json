{
	"appId": "com.metromaleclinic.metromale",
	"appName": "Metromale",
	"webDir": "build",
	"android": {
		"versionCode": 5,
		"versionName": "1.2.0"
	},
	"server": {
		"androidScheme": "https",
		"iosScheme": "appwrite-callback-metromale"
	},
	"plugins": {
		"App": {
			"scheme": "com.metromaleclinic.metromale"
		},
		"StatusBar": {
			"overlaysWebView": false,
			"style": "LIGHT",
			"backgroundColor": "#ffffff"
		},
		"PushNotifications": {
			"presentationOptions": ["badge", "sound", "alert"]
		}
	}
}
